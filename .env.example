# --- Database (Neon Postgres recommended for Vercel) ---
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# --- Auth ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
SESSION_SECRET=replace-with-openssl-rand-hex-32
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.vercel.app

# --- Email digest (pick one; Resend preferred on Vercel) ---
RESEND_API_KEY=
# --- OR Gmail SMTP fallback ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Best7DaysMula <noreply@example.com>

# --- Vercel Cron auth (set this in Vercel dashboard env; cron sends it as Bearer) ---
CRON_SECRET=replace-with-openssl-rand-hex-32

# --- Optional: extra preview-deployment origins for CORS (comma-separated) ---
FRONTEND_URL_PREVIEWS=

# --- Local-dev only ---
BEST7DAYS_DB_PATH=data/best7days.duckdb
